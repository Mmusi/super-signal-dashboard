# Super Signal Dashboard — Environment Variables
# Copy to .env and fill in your values

# === SYSTEM MODE ===
# PAPER = paper trading (default, safe)
# LIVE  = real orders — USE WITH EXTREME CAUTION
# BACKTEST = backtest mode
MODE=PAPER

# === SERVER ===
PORT=3001

# === TELEGRAM ALERTS (optional) ===
# Create a Telegram bot via @BotFather
# Get your chat ID via @userinfobot
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === EXCHANGE API (LIVE mode only) ===
# Only needed when MODE=LIVE
# Get from your Binance/OKX API management page
BINANCE_API_KEY=
BINANCE_SECRET=

OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=

# === ACTIVE EXCHANGE (binance | okx) ===
EXCHANGE=binance
