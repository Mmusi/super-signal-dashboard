# Super Signal Dashboard — Environment Variables
# Copy this file to .env and fill in your values

# === SYSTEM MODE ===
MODE=PAPER   # PAPER | LIVE | BACKTEST

# === SERVER ===
PORT=3001

# === TELEGRAM ALERTS (optional) ===
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === BINGX API (for live trade execution) ===
# Get from: BingX → Account → API Management → Create API
# Required permissions: Trade (read + write), Account Info
# Recommended: restrict to your IP address for security


# === BINANCE (market data only — read-only, no trading) ===
BINANCE_API_KEY=
BINANCE_SECRET=



# === EXCHANGE (market data source) ===
EXCHANGE=binance
