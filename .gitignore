# ═══════════════════════════════════════════════════════════════════
#  SUPER SIGNAL DASHBOARD — .gitignore
#  Place at ROOT of project (same level as README.md and package.json)
# ═══════════════════════════════════════════════════════════════════

# ── SECRETS — NEVER commit these ─────────────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.*.local
backend/.env
backend/.env.*
!backend/.env.example

# ── Node dependencies ─────────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Database files ────────────────────────────────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
data/
backend/data/

# ── Build output ──────────────────────────────────────────────────────
dist/
build/
frontend/dist/
frontend/build/
.vite/

# ── Logs ──────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS files ──────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
ehthumbs.db

# ── IDE / Editor ──────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ── Test coverage ─────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Historical data cache ─────────────────────────────────────────────
data/historical/
backend/data/historical/

# ── Temporary ─────────────────────────────────────────────────────────
*.tmp
*.temp
.cache/
.parcel-cache/

# ── Docker overrides ──────────────────────────────────────────────────
docker-compose.override.yml

# ── Alternative lock files (keep package-lock.json only) ─────────────
yarn.lock
pnpm-lock.yaml

# ── Windows ───────────────────────────────────────────────────────────
$RECYCLE.BIN/
*.lnk